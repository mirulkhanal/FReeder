{
  "name": "FReeder",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "start": "react-native start",
    "clean:dist": "node ./scripts/clean-dist.mjs",
    "build:bundle:android": "react-native bundle --platform android --entry-file index.js --bundle-output dist/index.android.bundle --assets-dest dist/assets/android --dev false --minify true",
    "build:apk:release": "cd android && ./gradlew assembleRelease",
    "build:release-artifact": "npm run clean:dist && npm run build:apk:release && node ./scripts/create-release-artifact.mjs",
    "postinstall": "patch-package",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-documents/picker": "^12.0.1",
    "@react-native/new-app-screen": "0.86.0",
    "@react-navigation/bottom-tabs": "^7.18.3",
    "@react-navigation/native": "^7.3.4",
    "@react-navigation/native-stack": "^7.17.6",
    "fflate": "^0.8.3",
    "jszip": "^3.10.1",
    "lottie-react-native": "^7.3.8",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-blob-util": "^0.24.10",
    "react-native-file-access": "^4.0.3",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-keychain": "^10.0.0",
    "react-native-nitro-modules": "^0.35.10",
    "react-native-readium": "^5.0.0-rc.17",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.25.2",
    "react-native-share": "^12.3.1",
    "react-native-vector-icons": "^10.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/react": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
